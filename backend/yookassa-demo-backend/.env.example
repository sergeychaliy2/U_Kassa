# Положите тестовые данные YooKassa из sandbox (если вы тестируете).
# В проде указываются реальные shopId/secretKey.

PORT=3000

YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key

# Опционально: если вы хотите защитить endpoint от “левых” запросов Unity.
# Тогда в Unity включите Backend Client Key с тем же значением.
# BACKEND_CLIENT_KEY=some_shared_secret
BACKEND_CLIENT_KEY=

